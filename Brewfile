# =============================================================================
# BREWFILE
# declares all dependencies for a fresh Mac setup
# usage: brew bundle
# install brew first: /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
# =============================================================================

# -----------------------------------------------------------------------
# CLI tools
# -----------------------------------------------------------------------
brew "neovim"         # editor
brew "tmux"           # terminal multiplexer
brew "git"            # version control
brew "stow"           # symlink manager for dotfiles

# -----------------------------------------------------------------------
# Terminal
# -----------------------------------------------------------------------
cask "ghostty"        # terminal emulator

# -----------------------------------------------------------------------
# Fonts
# -----------------------------------------------------------------------
cask "font-jetbrains-mono"   # neovim + ghostty font
